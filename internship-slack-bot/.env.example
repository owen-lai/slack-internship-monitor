# Copy this file to .env and fill in the values before running.
# Never commit .env to version control.

# Bot token from your Slack app (Settings > OAuth & Permissions)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Channel ID to post in (right-click channel → View channel details → copy ID)
SLACK_CHANNEL_ID=C0123456789

# Source repo (default shown; override if you fork it)
GITHUB_REPO_URL=https://github.com/vanshb03/Summer2026-Internships

# How often to check for new listings when running locally (seconds)
CHECK_INTERVAL_SECONDS=60

# App-Level Token for Socket Mode (Settings > Socket Mode > Enable > generate token)
# Requires the connections:write scope on the token.
SLACK_APP_TOKEN=xapp-your-app-token-here

# Set to "true" to run a single check and exit (used by GitHub Actions)
# RUN_ONCE=false
