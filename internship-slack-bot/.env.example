# Copy this file to .env and fill in the values before running.
# Never commit .env to version control.

# Bot token from your Slack app (Settings > OAuth & Permissions)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Channel ID to post in (right-click channel → View channel details → copy ID)
SLACK_CHANNEL_ID=C0123456789

# Source repo (default shown; override if you fork it)
GITHUB_REPO_URL=https://github.com/vanshb03/Summer2026-Internships

# GitHub personal access token with the `gist` scope
# (cannot be named GITHUB_TOKEN in Actions — use GH_GIST_TOKEN as the secret name)
GITHUB_TOKEN=ghp-your-personal-access-token-here

# ID of the private Gist used to persist seen_ids.json across runs
# Create it at https://gist.github.com with a file named seen_ids.json containing {}
GIST_ID=your-gist-id-here
